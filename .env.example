# =============================================================================
# .env.example — Room Preview Application
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Do NOT commit real secrets to Git.
# Secret values will be shared via a secure channel.
# =============================================================================


# -----------------------------------------------------------------------------
# App — Public URL (required in production, used for QR code generation)
# NEXT_PUBLIC_ prefix means this value is exposed to the browser.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=


# -----------------------------------------------------------------------------
# Database — PostgreSQL
# DATABASE_URL: connection via pooler (e.g. PgBouncer, Neon pooled, Supabase pooled)
# DIRECT_URL:   direct connection used by Prisma for migrations (optional but recommended)
# DATABASE_POOL_SIZE: connection pool size (optional, default: 5)
# -----------------------------------------------------------------------------
DATABASE_URL=
DIRECT_URL=
DATABASE_POOL_SIZE=


# -----------------------------------------------------------------------------
# Redis — required in production for SSE pub/sub, render locks, and rate limiting
# ENABLE_REDIS: set to "false" to disable Redis in development (optional)
# -----------------------------------------------------------------------------
REDIS_URL=
ENABLE_REDIS=


# -----------------------------------------------------------------------------
# Storage — cloud storage is required in production
# STORAGE_PROVIDER: "r2" or "s3" — "local" is rejected in production
# The following R2/S3 variables are required when STORAGE_PROVIDER is not "local"
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=


# -----------------------------------------------------------------------------
# AI — Google Gemini (server-side only, never exposed to the client)
# GEMINI_API_KEY:          required in production — provided by developer via secure channel
# GEMINI_IMAGE_MODELS:     optional — comma-separated model names, has code defaults
# GEMINI_MAX_CONCURRENT:   optional — max concurrent Gemini calls (default: 8)
# GEMINI_CALL_TIMEOUT_MS:  optional — Gemini API call timeout in ms (default: 150000, min: 60000, max: 240000)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_IMAGE_MODELS=
GEMINI_MAX_CONCURRENT=
GEMINI_CALL_TIMEOUT_MS=


# -----------------------------------------------------------------------------
# Security — Secrets (server-side only)
# SESSION_TOKEN_SECRET: HMAC secret for mobile session tokens
#   → generate with: openssl rand -hex 32
# ADMIN_JWT_SECRET:     HMAC secret for admin panel session cookies
#   → generate with: openssl rand -hex 32
# ADMIN_USERNAME:       admin panel login username (optional — disables login if empty)
# ADMIN_PASSWORD:       admin panel login password (optional — disables login if empty)
# CLEANUP_SECRET:       protects the cleanup cron endpoint (any random string)
# CRON_SECRET:          bearer token for Vercel Cron (optional — auto-set by Vercel)
# -----------------------------------------------------------------------------
SESSION_TOKEN_SECRET=
ADMIN_JWT_SECRET=
ADMIN_USERNAME=
ADMIN_PASSWORD=
CLEANUP_SECRET=
CRON_SECRET=


# -----------------------------------------------------------------------------
# Session & Render Tuning (optional — all have code defaults)
# SESSION_EXPIRY_MINUTES:         session TTL in minutes (default: 60)
# MAX_RENDERS_PER_SESSION:        max AI renders per session (default: 2)
# ROOM_PREVIEW_DISABLE_RATE_LIMIT: set to "true" to bypass rate limiting (dev only)
# -----------------------------------------------------------------------------
SESSION_EXPIRY_MINUTES=
MAX_RENDERS_PER_SESSION=
ROOM_PREVIEW_DISABLE_RATE_LIMIT=


# -----------------------------------------------------------------------------
# Seller Authentication (Phase 1) — server-side only, never exposed to browser
# SELLER_SESSION_SECRET: signs the seller_session JWT. SEPARATE from
#   SESSION_TOKEN_SECRET (customer) and ADMIN_JWT_SECRET (admin).
#   → generate with: openssl rand -hex 32  (must be >= 32 chars in production)
# -----------------------------------------------------------------------------
SELLER_SESSION_SECRET=


# -----------------------------------------------------------------------------
# Chatbot integration — server-side only, NEVER exposed to the browser or
# prefixed NEXT_PUBLIC_. The browser never calls FastAPI directly: the 3d server
# proxies /api/seller/chat → FastAPI /internal/chat with a short-lived token.
#
# CHATBOT_FASTAPI_URL:  base URL of the chatbot FastAPI service (private network),
#   e.g. http://localhost:8001 in dev. Used by the seller-chat proxy (Phase 2D).
# EXTERNAL_SELLER_JWT_SECRET: signs the short-lived external-seller JWT sent to
#   FastAPI /internal/chat. MUST match the FastAPI service's value. SEPARATE trust
#   boundary: must differ from SELLER_SESSION_SECRET and from INTERNAL_JWT_SECRET
#   (no fallback). Generate with: openssl rand -hex 32
# SELLER_CHAT_ENABLED: optional feature flag for the seller-chat proxy. Defaults
#   ON in dev; set to "true" in production to enable, "false" to disable (503).
# INTERNAL_JWT_SECRET: signs short-lived admin-to-FastAPI internal JWTs. MUST
#   match the FastAPI service value and stay distinct from EXTERNAL_SELLER_JWT_SECRET
#   and SELLER_SESSION_SECRET. Generate with: openssl rand -hex 32
# CHATBOT_DATABASE_URL: only if the 3d server ever queries the chatbot DB directly
#   (it does NOT — FastAPI owns inventory/technical-document/chat data).
# -----------------------------------------------------------------------------
CHATBOT_FASTAPI_URL=
EXTERNAL_SELLER_JWT_SECRET=
SELLER_CHAT_ENABLED=
INTERNAL_JWT_SECRET=
CHATBOT_DATABASE_URL=


# -----------------------------------------------------------------------------
# Monitoring — Sentry (optional)
# NEXT_PUBLIC_SENTRY_DSN: exposed to browser for client-side error tracking
# SENTRY_ORG / SENTRY_PROJECT: used at build time for source map uploads
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
