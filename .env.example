# =============================================================================
# .env.example — Room Preview Application
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Do NOT commit real secrets to Git.
# Secret values will be shared via a secure channel.
# =============================================================================


# -----------------------------------------------------------------------------
# App — Public URL (required in production, used for QR code generation)
# NEXT_PUBLIC_ prefix means this value is exposed to the browser.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=


# -----------------------------------------------------------------------------
# Database — PostgreSQL
# DATABASE_URL: connection via pooler (e.g. PgBouncer, Neon pooled, Supabase pooled)
# DIRECT_URL:   direct connection used by Prisma for migrations (optional but recommended)
# DATABASE_POOL_SIZE: connection pool size (optional, default: 5)
# -----------------------------------------------------------------------------
DATABASE_URL=
DIRECT_URL=
DATABASE_POOL_SIZE=


# -----------------------------------------------------------------------------
# Redis — required in production for SSE pub/sub, render locks, and rate limiting
# ENABLE_REDIS: set to "false" to disable Redis in development (optional)
# -----------------------------------------------------------------------------
REDIS_URL=
ENABLE_REDIS=


# -----------------------------------------------------------------------------
# Storage — cloud storage is required in production
# STORAGE_PROVIDER: "r2" or "s3" — "local" is rejected in production
# The following R2/S3 variables are required when STORAGE_PROVIDER is not "local"
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=


# -----------------------------------------------------------------------------
# AI — Google Gemini (server-side only, never exposed to the client)
# GEMINI_API_KEY:       required in production — provided by developer via secure channel
# GEMINI_IMAGE_MODELS:  optional — comma-separated model names, has code defaults
# GEMINI_MAX_CONCURRENT: optional — max concurrent Gemini calls (default: 8)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_IMAGE_MODELS=
GEMINI_MAX_CONCURRENT=


# -----------------------------------------------------------------------------
# Security — Secrets (server-side only)
# SESSION_TOKEN_SECRET: HMAC secret for mobile session tokens
#   → generate with: openssl rand -hex 32
# ADMIN_JWT_SECRET:     HMAC secret for admin panel session cookies
#   → generate with: openssl rand -hex 32
# ADMIN_USERNAME:       admin panel login username (optional — disables login if empty)
# ADMIN_PASSWORD:       admin panel login password (optional — disables login if empty)
# CLEANUP_SECRET:       protects the cleanup cron endpoint (any random string)
# CRON_SECRET:          bearer token for Vercel Cron (optional — auto-set by Vercel)
# -----------------------------------------------------------------------------
SESSION_TOKEN_SECRET=
ADMIN_JWT_SECRET=
ADMIN_USERNAME=
ADMIN_PASSWORD=
CLEANUP_SECRET=
CRON_SECRET=


# -----------------------------------------------------------------------------
# Session & Render Tuning (optional — all have code defaults)
# SESSION_EXPIRY_MINUTES:         session TTL in minutes (default: 60)
# MAX_RENDERS_PER_SESSION:        max AI renders per session (default: 2)
# ROOM_PREVIEW_DISABLE_RATE_LIMIT: set to "true" to bypass rate limiting (dev only)
# -----------------------------------------------------------------------------
SESSION_EXPIRY_MINUTES=
MAX_RENDERS_PER_SESSION=
ROOM_PREVIEW_DISABLE_RATE_LIMIT=


# -----------------------------------------------------------------------------
# Monitoring — Sentry (optional)
# NEXT_PUBLIC_SENTRY_DSN: exposed to browser for client-side error tracking
# SENTRY_ORG / SENTRY_PROJECT: used at build time for source map uploads
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
