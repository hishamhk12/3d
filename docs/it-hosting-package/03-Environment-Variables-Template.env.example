# ============================================================================
# قالب متغيّرات البيئة — تطبيق الـ3D / Seller Chat
# الأسماء فقط — بدون أي قيم. لا تضع أسراراً هنا.
# المصدر: استخراج فعلي من كود المشروع (lib/env.ts, lib/storage.ts, lib/seller/*).
# الأسرار تُدار عبر Secret Manager أو منصّة الاستضافة، لا داخل Git.
# ============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
NODE_ENV=                      # production | development
NEXT_PUBLIC_BASE_URL=          # عنوان التطبيق العام (لتوليد QR) — علني
PORT=                          # منفذ التشغيل (افتراضي 3000) — اختياري
LOG_LEVEL=                     # مستوى السجلّات (pino) — اختياري

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=                  # سلسلة اتصال PostgreSQL
DATABASE_POOL_SIZE=            # حجم Connection pool — اختياري

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=                     # اتصال Redis (rate-limit / locks / SSE pub-sub)
ENABLE_REDIS=                  # تفعيل Redis صراحةً — اختياري

# ---------------------------------------------------------------------------
# Storage (Object Storage — S3-compatible / R2)
# ---------------------------------------------------------------------------
STORAGE_PROVIDER=              # local | r2 | s3  (يجب r2 أو s3 في الإنتاج)
R2_ENDPOINT=                   # عنوان خدمة التخزين
R2_BUCKET_NAME=                # اسم الـbucket
R2_ACCESS_KEY_ID=              # مفتاح الوصول (سرّي)
R2_SECRET_ACCESS_KEY=          # سرّ الوصول (سرّي)
R2_PUBLIC_URL=                 # عنوان القراءة العام للملفات

# ---------------------------------------------------------------------------
# Gemini (AI Render)
# ---------------------------------------------------------------------------
GEMINI_API_KEY=                # مفتاح Google Gemini (سرّي)
GEMINI_IMAGE_MODELS=           # نماذج الصور — اختياري
GEMINI_MAX_CONCURRENT=         # حدّ التزامن — اختياري
GEMINI_CALL_TIMEOUT_MS=        # مهلة الاستدعاء — اختياري

# ---------------------------------------------------------------------------
# Seller Authentication
# ---------------------------------------------------------------------------
SELLER_SESSION_SECRET=         # توقيع جلسة البائع seller_session (سرّي)

# ---------------------------------------------------------------------------
# JWT and Internal Services
# ---------------------------------------------------------------------------
SESSION_TOKEN_SECRET=          # توقيع رموز جلسات Room Preview (سرّي)
EXTERNAL_SELLER_JWT_SECRET=    # توقيع رمز البائع المرسل إلى FastAPI (سرّي، يطابق FastAPI)
INTERNAL_JWT_SECRET=           # توقيع رمز Admin المرسل إلى FastAPI (سرّي، يطابق FastAPI)
CLEANUP_SECRET=                # حماية مسار cron للتنظيف (سرّي)

# ---------------------------------------------------------------------------
# FastAPI
# ---------------------------------------------------------------------------
CHATBOT_FASTAPI_URL=           # عنوان خدمة FastAPI (server-only، شبكة خاصة)

# ---------------------------------------------------------------------------
# Admin
# ---------------------------------------------------------------------------
ADMIN_USERNAME=                # اسم مستخدم لوحة الإدارة
ADMIN_PASSWORD=                # كلمة مرور لوحة الإدارة (سرّي)
ADMIN_JWT_SECRET=              # توقيع جلسة الإدارة (سرّي)

# ---------------------------------------------------------------------------
# Monitoring (Sentry)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=        # عنوان Sentry (علني)
SENTRY_ORG=                    # منظمة Sentry — للبناء
SENTRY_PROJECT=                # مشروع Sentry — للبناء

# ---------------------------------------------------------------------------
# Feature Flags
# ---------------------------------------------------------------------------
SELLER_CHAT_ENABLED=           # تفعيل/إيقاف Seller Chat

# ---------------------------------------------------------------------------
# Optional / Proposed  (اختيارية أو ضبط متقدّم — ليست مطلوبة للتشغيل الأساسي)
# ---------------------------------------------------------------------------
CRON_SECRET=                   # سرّ بديل لجدولة المهام — اختياري
DEBUG_SECRET=                  # حماية مسار تشخيص — اختياري
OPENAI_API_KEY=                # مزوّد AI اختياري (Gemini هو الأساسي) — يحتاج تأكيد
MAX_RENDERS_PER_SESSION=       # حدّ عدد عمليات التوليد لكل جلسة — اختياري
SESSION_EXPIRY_MINUTES=        # مدة صلاحية الجلسة — اختياري
ROOM_PREVIEW_RENDER_LONG_EDGE= # أبعاد إخراج الرندر — اختياري
ROOM_PREVIEW_RENDER_QUALITY=   # جودة الرندر — اختياري
ROOM_PREVIEW_SINGLE_SCREEN_MODE= # وضع شاشة واحدة — اختياري
ROOM_PREVIEW_DISABLE_RATE_LIMIT= # تعطيل حدود الطلبات (تطوير فقط) — اختياري
# CHATBOT_DATABASE_URL=        # مذكور سابقاً لكنه غير مستخدم في الـ3d (الـFastAPI يملك بيانات المخزون)

# ملاحظة: متغيّرات مثل VERCEL_ENV / VERCEL_REGION / NEXT_PHASE / NEXT_RUNTIME
# تُحقَن تلقائياً من منصّة الاستضافة ولا تُضبط يدوياً.
